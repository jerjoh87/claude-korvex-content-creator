# Korvex OS environment configuration
# Copy to .env.local for local dev; set the same vars in Vercel/host for production.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (project: pvtufzlrwsejoefxjkjc) ---
# Dashboard: https://supabase.com/dashboard/project/pvtufzlrwsejoefxjkjc
# Keys: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://pvtufzlrwsejoefxjkjc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# --- Social token encryption (32+ char random string) ---
# Generate with: openssl rand -hex 32
SOCIAL_TOKEN_ENCRYPTION_KEY=

# --- AI providers (either enables live generation; both optional — app falls back to sample mode) ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Social OAuth apps (set the ones you've created; cards show Connect regardless) ---
META_CLIENT_ID=
META_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# --- Optional flags ---
# ENABLE_SOCIAL_AUTO_POSTING=true
